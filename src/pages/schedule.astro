---
import { getCollection } from 'astro:content';
import Page from '@layouts/Page.astro';
import CustomSection from '@builders/custom-section/CustomSection.astro';
import Heading from '@core-elements/heading/Heading.astro';

const days = (await getCollection('schedule')).sort((a, b) => a.data.order - b.data.order);
---

<Page title="Schedule" description="The full multi-day Otago Polyfest performance schedule.">
  <CustomSection maxContentWidth="lg" paddingHorizontal="lg" paddingVertical="2xl">
    <Heading level="h1" size="2xl" text="Festival Schedule" editable={false} />
    <p class="schedule-intro">
      <span data-lang-text="en">Times and running order are subject to change closer to the day.</span
      ><span data-lang-text="mi" hidden>[Add te reo Māori translation]</span>
    </p>

    {days.length === 0 && <p>The schedule hasn't been published yet — check back soon.</p>}

    {
      days.map((day) => (
        <section class="schedule-day">
          <Heading level="h2" size="lg" text={`${day.data.label} — ${day.data.date}`} editable={false} />

          {day.data.sessions.length === 0 ? (
            <p>No sessions added for this day yet.</p>
          ) : (
            <table class="schedule-table">
              <thead>
                <tr>
                  <th scope="col">Time</th>
                  <th scope="col">Group</th>
                  <th scope="col">Stage</th>
                </tr>
              </thead>
              <tbody>
                {day.data.sessions.map((session) => (
                  <tr>
                    <td>{session.time}</td>
                    <td>
                      {session.group_name}
                      {session.notes && <span class="schedule-notes"> — {session.notes}</span>}
                    </td>
                    <td>{session.stage || '—'}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          )}
        </section>
      ))
    }
  </CustomSection>
</Page>

<style lang="pcss" is:global>
  @layer overrides {
    .schedule-intro {
      color: var(--color-text-muted);
      margin-block-end: var(--spacing-xl);
    }

    .schedule-day {
      margin-block-end: var(--spacing-2xl);
    }

    .schedule-table {
      border-collapse: collapse;
      margin-block-start: var(--spacing-md);
      width: 100%;

      th,
      td {
        border-bottom: 1px solid var(--color-border-subtle);
        padding: var(--spacing-sm) var(--spacing-md);
        text-align: left;
      }

      th {
        color: var(--color-text-strong);
        font-weight: var(--font-weight-semibold);
      }
    }

    .schedule-notes {
      color: var(--color-text-muted);
      font-size: 0.9em;
    }
  }
</style>
