---
// A small EN / MI toggle. Swaps every [data-lang-text] pair on the page and
// remembers the choice in localStorage. Kept intentionally simple for launch —
// this is a visibility toggle, not full i18n routing.
---

<button type="button" class="lang-toggle" id="lang-toggle" aria-label="Switch language">
  <span data-lang-btn="en">MI</span>
  <span data-lang-btn="mi" hidden>EN</span>
</button>

<script is:inline>
  (function () {
    function applyLang(lang) {
      document.documentElement.setAttribute('data-lang', lang);

      document.querySelectorAll('[data-lang-text]').forEach((el) => {
        const isMatch = el.getAttribute('data-lang-text') === lang;
        el.hidden = !isMatch;
      });

      var btn = document.getElementById('lang-toggle');
      if (btn) {
        // Button label shows the language you'd switch TO.
        btn.querySelectorAll('[data-lang-btn]').forEach((el) => {
          el.hidden = el.getAttribute('data-lang-btn') !== lang;
        });
      }
    }

    var stored = window.localStorage ? window.localStorage.getItem('otago-polyfest-lang') : null;
    applyLang(stored === 'mi' ? 'mi' : 'en');

    document.getElementById('lang-toggle')?.addEventListener('click', function () {
      var current = document.documentElement.getAttribute('data-lang') || 'en';
      var next = current === 'en' ? 'mi' : 'en';
      applyLang(next);
      try {
        window.localStorage.setItem('otago-polyfest-lang', next);
      } catch (e) {
        /* ignore storage errors */
      }
    });
  })();
</script>

<style lang="pcss" is:global>
  @layer components {
    .lang-toggle {
      background: transparent;
      border: 1px solid var(--color-border-strong);
      border-radius: var(--radius-xs);
      color: var(--color-text-strong);
      cursor: pointer;
      font-weight: var(--font-weight-semibold);
      padding: var(--spacing-xs) var(--spacing-sm);

      &:hover {
        background: var(--color-state-hover);
      }
    }
  }
</style>
