---
// Renders text that can toggle between English and te reo Māori based on the
// document's data-lang attribute (set by <LangToggle />). If no `mi` value is
// supplied yet, we just show the English text in both cases.
const { en = '', mi = '', as: Tag = 'span', ...htmlAttributes } = Astro.props;
const hasTranslation = Boolean(mi) && mi !== en;
---

{
  hasTranslation ? (
    <Tag {...htmlAttributes}>
      <span data-lang-text="en">{en}</span>
      <span data-lang-text="mi" hidden>
        {mi}
      </span>
    </Tag>
  ) : (
    <Tag {...htmlAttributes}>{en}</Tag>
  )
}
